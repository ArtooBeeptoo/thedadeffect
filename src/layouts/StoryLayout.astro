---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  story: CollectionEntry<'stories'>;
}

const { story } = Astro.props;
const { title, description, pubDate, categories, tags } = story.data;

function readingTime(text: string): number {
  return Math.ceil(text.split(/\s+/).length / 200);
}

// Article + Breadcrumb schema. Answer engines (AI Overviews, ChatGPT, Perplexity,
// Claude) lean on Article markup to decide what is quotable and who to credit.
// Stories previously shipped with no Article schema at all.
const SITE = 'https://thedadeffect.com';
const canonicalURL = new URL(Astro.url.pathname, SITE).href;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "dateModified": pubDate.toISOString(),
  "author": { "@type": "Organization", "name": "The Dad Effect", "url": SITE },
  "publisher": {
    "@type": "Organization",
    "name": "The Dad Effect",
    "url": SITE,
    "sameAs": ["https://x.com/DadEffect"]
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
  "url": canonicalURL,
  ...(tags?.length ? { "keywords": tags.join(', ') } : {}),
  ...(categories?.length ? { "articleSection": categories[0] } : {})
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE },
    { "@type": "ListItem", "position": 2, "name": "Stories", "item": `${SITE}/stories/` },
    { "@type": "ListItem", "position": 3, "name": title }
  ]
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <div class="container">
    <article class="single-story">
      <header class="story-header">
        <div class="story-meta">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {categories.map((cat: string) => (
            <span class="category">{cat}</span>
          ))}
          <span class="reading-time">{readingTime(story.body || '')} min read</span>
        </div>
        <h1>{title}</h1>
        {description && <p class="subtitle">{description}</p>}
      </header>
      <div class="prose">
        <slot />
      </div>
      <footer class="story-footer">
        {tags.length > 0 && (
          <div class="tags">
            {tags.map((tag: string) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
        <div class="share-story">
          <p>Know a dad who needs to hear this? Share it.</p>
          <a
            href={`https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}&via=DadEffect`}
            target="_blank"
            class="btn btn-secondary"
          >
            Share on 𝕏
          </a>
        </div>
      </footer>
    </article>
  </div>
</BaseLayout>
